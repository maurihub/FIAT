<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fiat Plan Argentina | Sitio Oficial 2026</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cloudflare.com">
    <style>
        :root {
            --fiat-red: #B11016;
            --fiat-dark: #121212;
            --fiat-grey: #f0f0f0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; }
        
        body { 
            background-color: var(--fiat-grey);
            background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' width='200' height='100' viewBox='0 0 200 100'%3E%3Ctext x='10' y='60' font-family='Arial' font-size='40' font-weight='bold' fill='%23000' fill-opacity='0.03'%3EFIAT%3C/text%3E%3C/svg%3E");
            color: #333;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        nav {
            background: #fff;
            padding: 15px 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 5px solid var(--fiat-red);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .logo-fiat { height: 45px; }

        .btn-header {
            background: var(--fiat-red);
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 700;
            font-size: 0.8rem;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.3)), 
                        url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            height: 50vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 0 20px;
        }
        .hero h1 { font-size: 3.5rem; font-weight: 900; }

        .container { max-width: 1300px; margin: 0 auto; padding: 60px 20px; }
        .title-section { text-align: center; margin-bottom: 50px; }
        .title-section h2 { font-size: 2.5rem; font-weight: 900; text-transform: uppercase; }

        .grid-modelos {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            transition: 0.4s;
            text-align: center;
            border: 1px solid #eee;
        }
        .card:hover { transform: translateY(-10px); box-shadow: 0 15px 35px rgba(177, 16, 22, 0.2); }
        
        /* Ajuste de imágenes para asegurar visibilidad */
        .card img { 
            width: 100%; 
            height: 200px; 
            object-fit: contain; 
            padding: 15px;
            display: block;
            margin: 0 auto;
        }
        
        .card-content { padding: 20px; background: #fafafa; }
        .card-content h3 { font-size: 1.5rem; margin-bottom: 15px; font-weight: 900; }

        .btn-card {
            display: inline-block;
            background: var(--fiat-red);
            color: #fff;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 700;
        }

        .contact-section { background: var(--fiat-dark); color: white; padding: 60px 5%; text-align: center; }
        .form-group { margin-bottom: 15px; text-align: left; max-width: 500px; margin-left: auto; margin-right: auto; }
        .form-group input, .form-group select { width: 100%; padding: 12px; border-radius: 5px; border: none; }
        
        .btn-submit { background: var(--fiat-red); color: white; border: none; padding: 15px 30px; font-weight: 900; cursor: pointer; width: 100%; max-width: 500px; border-radius: 5px; }

        .ws-float {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            z-index: 1000;
        }

        footer { background: #000; color: #555; text-align: center; padding: 30px; font-size: 0.8rem; }
    </style>
</head>
<body>

    <nav>
        <img src="https://wikimedia.org" alt="Fiat" class="logo-fiat">
        <a href="#contacto" class="btn-header">CONTACTO</a>
    </nav>

    <header class="hero">
        <h1>GAMA FIAT 2026</h1>
        <p>ENTREGA PACTADA</p>
    </header>

    <div class="container">
        <div class="title-section">
            <h2>NUESTROS MODELOS</h2>
        </div>

        <div class="grid-modelos">
            <div class="card">
                <img src="https://fiat.com.ar" alt="Cronos">
                <div class="card-content">
                    <h3>CRONOS</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <div class="card">
                <img src="https://fiat.com.ar" alt="Strada">
                <div class="card-body card-content">
                    <h3>STRADA</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <div class="card">
                <img src="https://fiat.com.ar" alt="Toro">
                <div class="card-content">
                    <h3>TORO</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <div class="card">
                <img src="https://fiat.com.ar" alt="Pulse">
                <div class="card-content">
                    <h3>PULSE</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <div class="card">
                <img src="https://fiat.com.ar" alt="Fastback">
                <div class="card-content">
                    <h3>FASTBACK</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
        </div>
    </div>

    <section class="contact-section" id="contacto">
        <h2 style="margin-bottom: 20px;">ASESORAMIENTO OFICIAL</h2>
        <form>
            <div class="form-group">
                <input type="text" placeholder="Nombre" required>
            </div>
            <div class="form-group">
                <input type="tel" placeholder="WhatsApp" required>
            </div>
            <button type="submit" class="btn-submit">ENVIAR CONSULTA</button>
        </form>
    </section>

    <a href="https://wa.me" class="ws-float">
        <i class="fab fa-whatsapp"></i>
    </a>

    <footer>
        <p>CONCESIONARIO OFICIAL FIAT &copy; 2026</p>
    </footer>

</body>
</html>
