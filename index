<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fiat Plan Argentina | Sitio Oficial 2026</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cloudflare.com">
    <style>
        :root { --fiat-red: #B11016; --fiat-dark: #121212; --fiat-grey: #f0f0f0; }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; }
        
        body { 
            background-color: var(--fiat-grey);
            background-image: url("data:image/svg+xml,%3Csvg xmlns='http://w3.org' width='200' height='100' viewBox='0 0 200 100'%3E%3Ctext x='10' y='60' font-family='Arial' font-size='30' font-weight='bold' fill='%23000' fill-opacity='0.03'%3EFIAT%3C/text%3E%3C/svg%3E");
        }

        nav {
            background: #fff;
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 5px solid var(--fiat-red);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .logo-fiat { height: 40px; }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.4)), url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            height: 45vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
        .grid-modelos { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }

        .card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            transition: 0.3s;
            text-align: center;
        }
        .card:hover { transform: translateY(-10px); }
        
        /* Imágenes forzadas a verse */
        .card img { 
            width: 100%; 
            height: 220px; 
            object-fit: contain; 
            padding: 15px;
            background: white;
            display: block;
        }
        
        .card-body { padding: 20px; background: #fafafa; border-top: 1px solid #eee; }
        .card-body h3 { font-size: 1.6rem; margin-bottom: 15px; font-weight: 900; color: var(--fiat-dark); }

        .btn-card {
            display: inline-block;
            background: var(--fiat-red);
            color: #fff;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 700;
            transition: 0.3s;
        }
        .btn-card:hover { background: var(--fiat-dark); }

        .contact-section { background: var(--fiat-dark); color: white; padding: 60px 5%; text-align: center; }
        .form-group { margin-bottom: 15px; max-width: 450px; margin-left: auto; margin-right: auto; }
        .form-group input, .form-group select { width: 100%; padding: 14px; border-radius: 5px; border: none; font-size: 1rem; }
        
        .btn-submit { background: var(--fiat-red); color: white; border: none; padding: 16px; font-weight: 900; cursor: pointer; width: 100%; max-width: 450px; border-radius: 5px; text-transform: uppercase; }

        .ws-float {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background: #25d366;
            color: white;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 35px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            z-index: 1000;
        }

        footer { background: #000; color: #555; text-align: center; padding: 30px; font-size: 0.8rem; }
    </style>
</head>
<body>

    <nav>
        <img src="https://wikimedia.org" alt="Fiat Logo" class="logo-fiat">
        <div style="font-weight: 900; color: var(--fiat-red); font-size: 0.8rem;">ENTREGA PACTADA 2026</div>
    </nav>

    <header class="hero">
        <h1 style="font-size: 3rem; font-weight: 900;">TU FIAT 0KM</h1>
        <p style="letter-spacing: 3px;">DIRECTO DE FÁBRICA</p>
    </header>

    <div class="container">
        <div class="grid-modelos">
            <!-- Cronos -->
            <div class="card">
                <img src="https://imgur.com" alt="Fiat Cronos">
                <div class="card-body">
                    <h3>CRONOS</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <!-- Strada -->
            <div class="card">
                <img src="https://imgur.com" alt="Fiat Strada">
                <div class="card-body">
                    <h3>STRADA</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <!-- Toro -->
            <div class="card">
                <img src="https://imgur.com" alt="Fiat Toro">
                <div class="card-body">
                    <h3>TORO</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <!-- Pulse -->
            <div class="card">
                <img src="https://imgur.com" alt="Fiat Pulse">
                <div class="card-body">
                    <h3>PULSE</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
            <!-- Fastback -->
            <div class="card">
                <img src="https://imgur.com" alt="Fiat Fastback">
                <div class="card-body">
                    <h3>FASTBACK</h3>
                    <a href="https://wa.me" class="btn-card">INFO WHATSAPP</a>
                </div>
            </div>
        </div>
    </div>

    <section class="contact-section" id="contacto">
        <h2 style="margin-bottom: 25px; font-weight: 900;">RECIBIR PRESUPUESTO</h2>
        <form>
            <div class="form-group"><input type="text" placeholder="Nombre completo" required></div>
            <div class="form-group"><input type="tel" placeholder="WhatsApp (Ej: 11 1234 5678)" required></div>
            <div class="form-group">
                <select>
                    <option>Elegir Modelo...</option>
                    <option>Cronos</option><option>Strada</option><option>Toro</option><option>Pulse</option><option>Fastback</option>
                </select>
            </div>
            <button type="submit" class="btn-submit">QUIERO MI ASESORAMIENTO</button>
        </form>
    </section>

    <a href="https://wa.me" class="ws-float" target="_blank">
        <i class="fab fa-whatsapp"></i>
    </a>

    <footer>
        <p><strong>CONCESIONARIO OFICIAL FIAT ARGENTINA &copy; 2026</strong></p>
    </footer>

</body>
</html>
